# Choose LLM provider: "google" or "groq"
LLM_PROVIDER=google

# ── Google Gemini ──
GOOGLE_API_KEY=your_gemini_api_key_here
MODEL=gemini-2.5-flash-lite

# ── Groq ──
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Optional context budgets (helps avoid 413 / TPM errors on smaller models)
LLM_MAX_USER_REQUEST_CHARS=500
LLM_MAX_BROWSER_OUTPUT_CHARS=1800
LLM_MAX_CRITIQUE_CHARS=700
LLM_MAX_PAGE_CONTENT_CHARS=2000
